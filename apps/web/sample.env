# LOCAL SUPABASE
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# GOOGLE API (for receipt scanning)
GOOGLE_API_KEY="your-google-api-key"

# RESEND (for email notifications)
# Get your API key from https://resend.com/
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="BrokeBesties <noreply@yourdomain.com>"

# App URL for email links (use http://localhost:3000 for local dev, production URL for deployed)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth Credentials (for Google SSO)
# Get these from https://console.cloud.google.com/
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET="your-google-client-secret"

# Seed user email (for initial database seeding)
SEED_USER_EMAIL='albert@mail.com'
# KAFKA (Aiven)
# Connection info from Aiven dashboard
KAFKA_BROKERS="your-service.aivencloud.com:12345"
KAFKA_USERNAME="avnadmin"
KAFKA_PASSWORD="your-password"

# TLS Certificates (paste contents with newlines as \n, e.g., "-----BEGIN CERTIFICATE-----\n...")
KAFKA_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
KAFKA_CLIENT_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
KAFKA_CLIENT_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Consumer authentication secret (use a random string, must match between trigger and consume routes)
KAFKA_CONSUMER_SECRET="your-random-consumer-secret-string"
